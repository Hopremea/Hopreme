# === Clerk (authentification) ===
# Dashboard Clerk > API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_live_votre_cle_publique
CLERK_SECRET_KEY=sk_live_votre_cle_secrete

# === Anthropic (relais IA, clé jamais exposée au navigateur) ===
ANTHROPIC_API_KEY=sk-ant-votre_cle_dediee

# === Supabase (base partagée, navigateur) ===
# Project Settings > API. La clé anon est publique (protégée par les règles RLS).
# Si absentes, l'app retombe sur localStorage (mono-poste, sans synchronisation).
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_publique

# === Shopify (lecture du stock, relais serveur, jeton jamais exposé au navigateur) ===
# App personnalisée Shopify (Paramètres > Apps et canaux de vente > Développer des apps),
# scopes Admin API : read_products + read_inventory. Si absentes, la synchro Shopify est
# simplement désactivée (l'app continue de fonctionner). Voir /api/shopify.js.
SHOPIFY_STORE_DOMAIN=ma-boutique.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_votre_jeton_admin
