# === Clerk (authentification) ===
# Dashboard Clerk > API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_live_votre_cle_publique
CLERK_SECRET_KEY=sk_live_votre_cle_secrete

# === Anthropic (relais IA, clé jamais exposée au navigateur) ===
ANTHROPIC_API_KEY=sk-ant-votre_cle_dediee

# === Supabase (base partagée, navigateur) ===
# Project Settings > API. La clé anon est publique (protégée par les règles RLS).
# Si absentes, l'app retombe sur localStorage (mono-poste, sans synchronisation).
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_publique

# === Flux calendrier .ics (abonnement Google Agenda / Samsung Calendar) ===
# La fonction /api/calendar lit l'état partagé côté serveur pour servir un flux iCalendar,
# protégé par un jeton secret généré dans l'app (Calendrier → Connecter le calendrier).
# Elle a besoin de la clé service Supabase (Project Settings > API > service_role),
# qui reste côté serveur et contourne la RLS. Sans elle, le flux d'abonnement est désactivé
# (l'export .ics manuel continue de fonctionner).
SUPABASE_SERVICE_ROLE_KEY=votre_cle_service_role
# Facultatif : si non définie, /api/calendar réutilise VITE_SUPABASE_URL.
# SUPABASE_URL=https://votre-projet.supabase.co

# === Gmail (envoi d'e-mails via une boîte connectée — matthis-anael@penup3d.com) ===
# Permet à MITMIT d'ENVOYER des e-mails (bouton « Envoyer via Gmail » de l'assistant),
# avec la signature Gmail auto-injectée. Réutilise l'app OAuth Google d'Influence.
# Le jeton reste côté serveur (fonctions /api), jamais exposé au navigateur.
# 1) Ajoute l'URL de callback https://<domaine-mitmit>/api/auth/google/callback dans
#    les « Authorized redirect URIs » de l'app OAuth Google Cloud.
# 2) Renseigne les variables ci-dessous, déploie, ouvre /api/auth/google connecté au
#    bon compte Google → copie le refresh token affiché dans GOOGLE_REFRESH_TOKEN → redeploy.
GOOGLE_CLIENT_ID=485805045631-xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_USER_EMAIL=matthis-anael@penup3d.com
GOOGLE_REFRESH_TOKEN=
GMAIL_FROM_NAME=Matthis - MITMIT
NEXT_PUBLIC_APP_URL=https://votre-domaine-mitmit.vercel.app

# === Shopify (lecture du stock, relais serveur, jeton jamais exposé au navigateur) ===
# App personnalisée Shopify (Paramètres > Apps et canaux de vente > Développer des apps),
# scopes Admin API : read_products + read_inventory. Si absentes, la synchro Shopify est
# simplement désactivée (l'app continue de fonctionner). Voir /api/shopify.js.
SHOPIFY_STORE_DOMAIN=ma-boutique.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_votre_jeton_admin
